# Server
PORT=3100
NODE_ENV=development

# Internal API (X-API-Key) — shared with kppdf-3.0 ai-proxy
# Generate: openssl rand -hex 32
AI_SERVICE_API_KEY=change-me-shared-with-kppdf

# MongoDB (AI service — separate from KPPDF)
MONGO_URI=mongodb://localhost:27018/kppdf_ai

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=kppdf_knowledge
# 2048 — размерность nvidia/llama-nemotron-embed-vl-1b-v2:free (см. OPENROUTER_MODEL_EMBED)
QDRANT_VECTOR_SIZE=2048

# OpenRouter (LLM + embeddings) — бесплатные модели OpenRouter (:free)
OPENROUTER_API_KEY=
# Чат: GET /models — полный slug, для free добавьте :free
OPENROUTER_MODEL_CHAT=meta-llama/llama-3.3-70b-instruct:free
# Эмбеддинги: GET /embeddings/models (не путать с чат-моделями!)
# qwen/qwen-2.5-7b-instruct — только чат; для embed: qwen/qwen3-embedding-4b и т.п.
OPENROUTER_MODEL_EMBED=nvidia/llama-nemotron-embed-vl-1b-v2:free

# KPPDF integration
KPPDF_API_URL=http://localhost:3000/api/v1
KPPDF_AUTH_USERNAME=ai-sync
KPPDF_AUTH_PASSWORD=ai-sync123

# Schedulers (hours)
SYNC_INTERVAL_HOURS=12
NEWS_REFRESH_INTERVAL_HOURS=6

# News pipeline (fallback; override in admin → Новости: поиск)
NEWS_TOPICS_LIMIT=15
NEWS_RSS_PAUSE_MS=400
NEWS_MAX_RSS_ITEMS_PER_TOPIC=20
NEWS_SKIP_SYNC_IN_REFRESH=false
# Пакеты для LLM-curate (меньше = реже 429 на :free моделях)
NEWS_CURATE_BATCH_SIZE=8
NEWS_CURATE_PAUSE_MS=2000

# Admin UI (http://localhost:5174 dev, /admin in prod)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin
ADMIN_JWT_SECRET=change-me-admin-jwt-min-32-chars-recommended
ADMIN_ENCRYPTION_SECRET=change-me-32-char-encryption-secret!!

# Google Sheets (каталог — та же таблица, что kppdf-3.0/tools/products_import_export)
# ID из kppdf-3.0/tools/products_import_export/.env.example
GOOGLE_SHEET_ID=1HMUpCiQIRYfTphGJUIQkjNB9CuUe-q8gddNcJYnk72Y
# Production import/export (kppdf) — не трогаем при тестах
GOOGLE_SHEETS_PRODUCTS_RANGE=products!A1:ZZ5000
# Тестовый каталог ai-analyst без KPPDF (auto если GOOGLE credentials заданы)
CATALOG_SYNC_SOURCE=google_sheets
GOOGLE_SHEETS_CATALOG_RANGE=ai_analyst_catalog!A1:Z500
# Вариант A (как в kppdf products_import_export):
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Вариант B (как в yougile-sync-server) — путь к JSON ключу:
# GOOGLE_SERVICE_ACCOUNT_KEY=./config/google-service-account.json
